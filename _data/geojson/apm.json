        {
            "type": "Feature",
            "properties": {
                "name": "Cleveland Avenue",
                "description": "Cleveland Avenue connects to the CMAX line, bringing Westerville passengers to a two-seat trip to the airport. This stop also services Abbot Nutrition, a major employer, and the Fort Hayes Metropolitan Education Center. This area of the city is almost completely cut off from surrounding neighborhoods, so building a stop here provides access to educational and entertainment opportunities to the rest of the city.",
                "icon": "apm",
                "simple": "true",
                "id": 7,
                "type": "stop"
            },
            "geometry": {
